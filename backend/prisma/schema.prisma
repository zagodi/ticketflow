generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ORGANIZER
  ATTENDEE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ATTENDEE)
  createdAt DateTime @default(now())

  // Eventos que este usuário criou (quando role = ORGANIZER)
  eventsOrganized Event[] @relation("EventOrganizer")

  // Pedidos que este usuário fez (quando role = ATTENDEE)
  orders Order[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  bannerUrl   String?
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  organizerId String
  organizer   User   @relation("EventOrganizer", fields: [organizerId], references: [id])

  orders Order[]
}

model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(PENDING)
  amount    Decimal     @db.Decimal(10, 2)
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // O Ticket só é criado depois que o pagamento é confirmado
  ticket Ticket?
}

model Ticket {
  id          String    @id @default(uuid())
  qrCode      String    @unique
  createdAt   DateTime  @default(now())
  checkedInAt DateTime?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])
}
